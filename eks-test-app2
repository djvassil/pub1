apiVersion: apps/v1
kind: Deployment
metadata:
  name: eks-test-app
  test: one
spec:
  replicas: 2
  selector:
    matchLabels:
      app: eks-test-app
  template:
    metadata:
      labels:
        app: eks-test-app
    spec:
      containers:
        - name: eks-test-app
          image: eks-test-app:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 3000

---
apiVersion: v1
kind: Service
metadata:
  name: eks-test-app-service
spec:
  selector:
    app: eks-test-app
  type: NodePort
  ports:
    - port: 80
      targetPort: 3000
      nodePort: 30080
